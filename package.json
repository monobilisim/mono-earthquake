{
  "name": "frontend",
  "version": "0.0.1",
  "devDependencies": {
    "@internationalized/date": "^3.12.2",
    "@libsql/client": "^0.17.3",
    "@lucide/svelte": "^1.26.0",
    "@sveltejs/kit": "^2.70.1",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.3",
    "@types/bun": "^1.3.14",
    "bits-ui": "2.18.1",
    "chart.js": "^4.5.1",
    "clsx": "^2.1.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "iconv-lite": "^0.7.3",
    "mode-watcher": "^1.1.0",
    "prettier": "^3.9.6",
    "prettier-plugin-svelte": "^4.1.1",
    "prettier-plugin-tailwindcss": "^0.8.1",
    "svelte": "^5.56.7",
    "svelte-adapter-bun": "^1.0.1",
    "svelte-check": "^4.7.3",
    "svelte-sonner": "^1.1.1",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^1.0.0",
    "tailwindcss": "^4.3.3",
    "tw-animate-css": "^1.3.8",
    "typescript": "^6.0.3",
    "vite": "^8.1.5"
  },
  "dependencies": {
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "pino-roll": "^4.0.0"
  },
  "private": true,
  "scripts": {
    "dev": "bun --bun run vite dev",
    "build": "BUILD_STEP=1 bun --bun run vite build",
    "preview": "bun --bun run vite preview",
    "prepare": "bun --bun run svelte-kit sync || echo ''",
    "check": "bun --bun run svelte-kit sync && bun --bun run svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "bun --bun run svelte-kit sync && bun --bun run svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "bun --bun run prettier --write . --ignore-path .prettierignore",
    "lint": "bun --bun run prettier --check .",
    "apply:schema": "bun --bun run src/lib/schema.ts",
    "db:push": "echo \"Push is not allowed\"",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:pull": "drizzle-kit pull"
  },
  "type": "module"
}
